terraform {
  required_version = ">= 1.6"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.0"
    }
  }
}

provider "aws" {
  region  = var.aws_region
  profile = var.aws_profile

  default_tags {
    tags = {
      Project     = var.project
      Environment = terraform.workspace   # automatically "dev" / "staging" / "prod"
      ManagedBy   = "terraform"
      Episode     = "EP05"
    }
  }
}
